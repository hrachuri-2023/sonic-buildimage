[Unit]
Description=Juniper QFX5241 initialization service
Before=pmon.service
After=sysinit.target
DefaultDependencies=no

[Service]
ExecStartPre=/usr/local/bin/juniper_qfx5240_64qd_util.py install
ExecStart=/usr/local/bin/juniper_qfx5240_64qd_monitor.py
RemainAfterExit=yes
StandardOutput=syslog+console
StandardError=syslog+console

[Install]
WantedBy=multi-user.target
